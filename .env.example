# Shared
NODE_ENV=production

# API
SERVICE_NAME=dynaprice-api
PORT=4000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dynaprice
REDIS_URL=redis://redis:6379/0
ML_SERVICE_URL=http://ml-service:8000

# PostgreSQL
POSTGRES_DB=dynaprice
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_PORT=6379
